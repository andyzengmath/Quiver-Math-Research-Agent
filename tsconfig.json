{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "webview-ui"
  ]
}
